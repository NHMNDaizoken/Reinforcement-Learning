{
  "name": "btck-traffic-dashboard",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "web:headless": "set CI=1&& set BROWSER=none&& set EXPO_UNSTABLE_HEADLESS=1&& expo start --web --port 8081",
